// Prisma schema for Mini Mall — micro e-commerce with membership system

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum MembershipLevel {
  REGULAR
  XINYUE1
  XINYUE2
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

// ─── Models ────────────────────────────────────────────────────────────────

model User {
  id              String          @id @default(cuid())
  name            String
  email           String          @unique
  password        String
  role            UserRole        @default(USER)
  membershipLevel MembershipLevel @default(REGULAR)
  totalSpent      Float           @default(0)

  cartItems CartItem[]
  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Float
  images      String   @default("[]") // JSON array of image URLs
  stock       Int      @default(0)
  isPublished Boolean  @default(true)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  quantity  Int      @default(1)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Order {
  id              String      @id @default(cuid())
  status          OrderStatus @default(PENDING)
  total           Float       // discounted total
  originalTotal   Float       // pre-discount total
  discount        Float       @default(0)
  membershipLevel MembershipLevel // snapshot of user's level at order time

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  name      String  // snapshot of product name
  price     Float   // snapshot of unit price (before discount)
  quantity  Int

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
}
